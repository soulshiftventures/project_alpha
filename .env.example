# =============================================================================
# Project Alpha - Environment Variables Template
# =============================================================================
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env files with real credentials to version control.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG_MODE=false
DRY_RUN_DEFAULT=true

# -----------------------------------------------------------------------------
# AI APIs (Core)
# -----------------------------------------------------------------------------
# Anthropic Claude - Primary AI reasoning
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI - Alternative AI provider (optional)
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------------------------
# Research & Search APIs
# -----------------------------------------------------------------------------
# Tavily - AI-powered web search
TAVILY_API_KEY=your_tavily_api_key_here

# Firecrawl - Web scraping and extraction
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# -----------------------------------------------------------------------------
# Lead Generation APIs
# -----------------------------------------------------------------------------
# Apollo.io - B2B lead database
APOLLO_API_KEY=your_apollo_api_key_here

# Outscraper - Google Maps data extraction
OUTSCRAPER_API_KEY=your_outscraper_api_key_here

# -----------------------------------------------------------------------------
# CRM
# -----------------------------------------------------------------------------
# HubSpot - CRM platform
HUBSPOT_API_KEY=your_hubspot_api_key_here
HUBSPOT_PORTAL_ID=your_portal_id_here

# -----------------------------------------------------------------------------
# Messaging & Notifications
# -----------------------------------------------------------------------------
# Telegram - Bot notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# SendGrid - Transactional email
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Project Alpha

# -----------------------------------------------------------------------------
# AI Enhancement Tools (Optional)
# -----------------------------------------------------------------------------
# AI-Q - Advanced reasoning enhancement
AIQ_API_KEY=your_aiq_api_key_here

# NemoClaw - Sandbox validation
NEMOCLAW_API_KEY=your_nemoclaw_api_key_here

# Zep - Memory persistence
ZEP_API_KEY=your_zep_api_key_here

# -----------------------------------------------------------------------------
# Operator Interface
# -----------------------------------------------------------------------------
PORT=5000
FLASK_DEBUG=false
